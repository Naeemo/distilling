# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/infodigest?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"

# AI Provider (Google Cloud Vertex AI Gemini)
GCP_PROJECT_ID="infodigest-prod"
VERTEX_AI_LOCATION="global"
VERTEX_AI_MODEL="gemini-2.0-flash"

# Optional local/custom OpenAI-compatible provider override (for Ollama during dev)
# LLM_PROVIDER_TYPE="custom"
# LLM_PROVIDER="ollama"
# LLM_BASE_URL="http://127.0.0.1:11434/v1"
# LLM_API_KEY="ollama"
# LLM_DEFAULT_MODEL="qwen3.5:2b"
# LLM_MODELS='["qwen3.5:2b"]'

# Frontend
FRONTEND_URL="http://localhost:3000"

# Server
PORT=3001
