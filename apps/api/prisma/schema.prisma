generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模块 ====================
model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String?
  avatar        String?
  password      String // bcrypt哈希
  role          UserRole           @default(USER)
  subscription  SubscriptionTier   @default(FREE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime? // 软删除

  // 关联
  contents   Content[]
  highlights Highlight[]
  tags       Tag[]
  reviews    Review[]

  @@index([email])
  @@index([subscription])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

// ==================== 内容模块 ====================
model Content {
  id            String        @id @default(cuid())
  userId        String
  url           String? // 可选（手动添加纯文本时为空）
  title         String
  contentText   String?       @db.Text // 提取的正文
  rawHtml       String?       @db.Text // 原始HTML（备用）
  summary       String?       @db.Text // 当前使用的摘要
  status        ContentStatus @default(UNREAD)
  sourceType    SourceType    @default(WEB)
  metadata      Json? // {author, publishDate, coverImage, siteName}
  // 阅读进度
  readingProgress Float       @default(0) // 阅读进度 0-100
  readingPosition Json? // {scrollY, paragraphIndex, timestamp}
  lastReadAt      DateTime?   // 最后阅读时间
  readCount       Int         @default(0) // 阅读次数
  readingTime     Int         @default(0) // 累计阅读时长（秒）
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // 关联
  user       User         @relation(fields: [userId], references: [id])
  highlights Highlight[]
  tags       ContentTag[]
  summaries  Summary[]
  reviews    Review[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([url])
  @@map("contents")
}

enum ContentStatus {
  UNREAD
  READING
  READ
  ARCHIVED
}

enum SourceType {
  WEB
  RSS
  NEWSLETTER
  MANUAL
}

// ==================== AI摘要模块 ====================
model Summary {
  id          String      @id @default(cuid())
  contentId   String
  summaryType SummaryType @default(QUICK)
  summaryText String      @db.Text
  tokensUsed  Int // 记录token消耗
  model       String // gpt-4o, gpt-3.5-turbo等
  createdAt   DateTime    @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([createdAt])
  @@map("summaries")
}

enum SummaryType {
  QUICK // 快速摘要（3-5句）
  DETAILED // 详细摘要
  BULLET // 要点形式
  QA // 问答形式
}

// ==================== 高亮/笔记模块 ====================
model Highlight {
  id            String   @id @default(cuid())
  contentId     String
  userId        String
  highlightText String   @db.Text
  note          String?  @db.Text
  color         String   @default("yellow") // yellow/green/blue/pink
  position      Json // {startOffset, endOffset, paragraphIndex}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([contentId])
  @@index([userId])
  @@map("highlights")
}

// ==================== 标签模块 ====================
model Tag {
  id            String   @id @default(cuid())
  userId        String
  name          String
  color         String   @default("#3b82f6")
  autoGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id])
  contents ContentTag[]

  @@unique([userId, name])
  @@map("tags")
}

model ContentTag {
  contentId String
  tagId     String

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@map("content_tags")
}

// ==================== 复习模块 ====================
model Review {
  id          String    @id @default(cuid())
  userId      String
  contentId   String
  reviewDate  DateTime // 计划复习日期
  completedAt DateTime? // 实际完成时间
  rating      Rating? // 评分（AGAIN/HARD/GOOD/EASY）
  interval    Int       @default(0) // 当前间隔天数
  easeFactor  Float     @default(2.5) // 难度系数（SM-2算法）
  repetitions Int       @default(0) // 成功复习次数
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId, reviewDate])
  @@index([contentId])
  @@map("reviews")
}

enum Rating {
  AGAIN // 完全忘记，间隔重置
  HARD // 困难，间隔小幅增加
  GOOD // 正常，间隔标准增加
  EASY // 简单，间隔大幅增加
}

// ==================== 邮件转发模块 ====================
model EmailForwardingConfig {
  id            String    @id @default(cuid())
  userId        String    @unique
  emailAddress  String    @unique // 专属转发邮箱地址 (如 save-xxxx@infodigest.app)
  isActive      Boolean   @default(true)
  provider      EmailProvider @default(MAILGUN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([emailAddress])
  @@index([userId])
  @@map("email_forwarding_configs")
}

enum EmailProvider {
  MAILGUN
  SENDGRID
  AWS_SES
  CUSTOM
}

model EmailReceived {
  id            String    @id @default(cuid())
  emailAddress  String    // 接收到的邮箱地址
  fromAddress   String    // 发件人
  subject       String    // 邮件主题
  body          String    @db.Text // 邮件正文
  parsedUrl     String?   // 从邮件中提取的URL
  parsedTitle   String?   // 从邮件中提取的标题
  parsedNotes   String?   // 从邮件中提取的笔记
  status        EmailProcessingStatus @default(PENDING)
  contentId     String?   // 成功处理后关联的内容ID
  errorMessage  String?   // 处理失败时的错误信息
  processedAt   DateTime? // 处理时间
  createdAt     DateTime  @default(now())

  @@index([emailAddress])
  @@index([status])
  @@index([createdAt])
  @@map("emails_received")
}

enum EmailProcessingStatus {
  PENDING     // 待处理
  PROCESSING  // 处理中
  COMPLETED   // 已完成
  FAILED      // 失败
}
