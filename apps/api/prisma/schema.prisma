generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模块 ====================
model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String?
  avatar        String?
  emailVerified Boolean            @default(false)
  password      String? // deprecated: migrated to Better Auth account table
  apiTokenHash  String?
  apiTokenPrefix String?           @unique
  role          UserRole           @default(USER)
  subscription  SubscriptionTier   @default(FREE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime? // 软删除

  // 关联
  accounts   Account[]
  sessions   Session[]
  contents   Content[]
  highlights Highlight[]
  tags       Tag[]
  reviews    Review[]
  submissions ContentSubmission[]
  insights   ContentInsight[]
  relations  ContentRelation[]
  clusters   TopicCluster[]

  @@index([email])
  @@index([apiTokenPrefix])
  @@index([subscription])
  @@map("users")
}

model Session {
  id          String   @id @default(cuid())
  expiresAt   DateTime
  token       String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ipAddress   String?
  userAgent   String?
  userId      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                      String    @id @default(cuid())
  accountId               String
  providerId              String
  userId                  String
  accessToken             String?
  refreshToken            String?
  idToken                 String?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  scope                   String?
  password                String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

// ==================== 内容模块 ====================
model Content {
  id            String        @id @default(cuid())
  userId        String
  url           String? // 可选（手动添加纯文本时为空）
  title         String
  contentText   String?       @db.Text // 提取的正文
  rawHtml       String?       @db.Text // 原始HTML（备用）
  summary       String?       @db.Text // 当前使用的摘要
  status        ContentStatus @default(UNREAD)
  sourceType    SourceType    @default(WEB)
  metadata      Json? // {author, publishDate, coverImage, siteName}
  // 阅读进度
  readingProgress Float       @default(0) // 阅读进度 0-100
  readingPosition Json? // {scrollY, paragraphIndex, timestamp}
  lastReadAt      DateTime?   // 最后阅读时间
  readCount       Int         @default(0) // 阅读次数
  readingTime     Int         @default(0) // 累计阅读时长（秒）
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // 关联
  user       User         @relation(fields: [userId], references: [id])
  highlights Highlight[]
  tags       ContentTag[]
  summaries  Summary[]
  submissions ContentSubmission[]
  reviews    Review[]
  insights   ContentInsight?
  relationsA ContentRelation[] @relation("ContentA")
  relationsB ContentRelation[] @relation("ContentB")
  clusters   ClusterContent[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([url])
  @@map("contents")
}

enum ContentStatus {
  UNREAD
  READING
  READ
  ARCHIVED
}

enum SourceType {
  WEB
  RSS
  NEWSLETTER
  MANUAL
}

model ContentSubmission {
  id                    String                  @id @default(cuid())
  userId                String
  contentId             String?
  duplicateOfSubmissionId String?
  source                ContentSubmissionSource
  status                ContentSubmissionStatus @default(FETCHING)
  title                 String
  url                   String?
  errorMessage          String?
  metadata              Json?
  submittedAt           DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  user                  User                    @relation(fields: [userId], references: [id])
  content               Content?                @relation(fields: [contentId], references: [id], onDelete: SetNull)
  duplicateOfSubmission ContentSubmission?      @relation("DuplicateSubmission", fields: [duplicateOfSubmissionId], references: [id], onDelete: SetNull)
  duplicateSubmissions  ContentSubmission[]     @relation("DuplicateSubmission")

  @@index([userId, submittedAt])
  @@index([contentId])
  @@index([duplicateOfSubmissionId])
  @@map("content_submissions")
}

enum ContentSubmissionSource {
  QUICK_PASTE
  BROWSER_EXTENSION
  IOS_SHORTCUT
}

enum ContentSubmissionStatus {
  FETCHING
  REUSING
  SUMMARIZING
  DIGESTED
  DUPLICATE
  FAILED
}

// ==================== AI摘要模块 ====================
model Summary {
  id          String      @id @default(cuid())
  contentId   String
  summaryType SummaryType @default(QUICK)
  summaryText String      @db.Text
  tokensUsed  Int // 记录token消耗
  model       String // gpt-4o, gpt-3.5-turbo等
  createdAt   DateTime    @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([createdAt])
  @@map("summaries")
}

enum SummaryType {
  QUICK // 快速摘要（3-5句）
  DETAILED // 详细摘要
  BULLET // 要点形式
  QA // 问答形式
}

// ==================== 高亮/笔记模块 ====================
model Highlight {
  id            String   @id @default(cuid())
  contentId     String
  userId        String
  highlightText String   @db.Text
  note          String?  @db.Text
  color         String   @default("yellow") // yellow/green/blue/pink
  position      Json // {startOffset, endOffset, paragraphIndex}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([contentId])
  @@index([userId])
  @@map("highlights")
}

// ==================== 标签模块 ====================
model Tag {
  id            String   @id @default(cuid())
  userId        String
  name          String
  color         String   @default("#3b82f6")
  autoGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id])
  contents ContentTag[]

  @@unique([userId, name])
  @@map("tags")
}

model ContentTag {
  contentId String
  tagId     String

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@map("content_tags")
}

// ==================== 复习模块 ====================
model Review {
  id          String    @id @default(cuid())
  userId      String
  contentId   String
  reviewDate  DateTime // 计划复习日期
  completedAt DateTime? // 实际完成时间
  rating      Rating? // 评分（AGAIN/HARD/GOOD/EASY）
  interval    Int       @default(0) // 当前间隔天数
  easeFactor  Float     @default(2.5) // 难度系数（SM-2算法）
  repetitions Int       @default(0) // 成功复习次数
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId, reviewDate])
  @@index([contentId])
  @@map("reviews")
}

enum Rating {
  AGAIN // 完全忘记，间隔重置
  HARD // 困难，间隔小幅增加
  GOOD // 正常，间隔标准增加
  EASY // 简单，间隔大幅增加
}

// ==================== 内容洞察模块 (知识图谱) ====================
model ContentInsight {
  id          String   @id @default(cuid())
  contentId   String   @unique
  userId      String
  
  // 主题分析
  topics      Json?    // [{name: "AI", confidence: 0.92}, ...]
  keyEntities Json?    // [{name: "OpenAI", type: "ORG", mentions: 5}, ...]
  sentiments  Json?    // {overall: "positive", score: 0.7}
  
  // 观点立场
  stance      String?  // "supportive", "critical", "neutral", "exploratory"
  keyClaims   Json?    // ["claim1", "claim2", ...]
  
  // 信息位置
  infoPosition Json?   // {domain: "tech", level: "deep", audience: "professional"}
  
  // 时间脉络
  temporalContext Json? // {eventTime: "2024-01", referenceType: "current_event"}
  
  // 质量与可信度
  qualityScore    Float?   // 0-1 综合质量评分
  credibilityScore Float?  // 0-1 可信度评分
  
  // 向量嵌入 (用于相似度计算)
  embedding Unsupported("vector(1536)")?   // pgvector 扩展
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([contentId])
  @@map("content_insights")
}

// ==================== 内容关联模块 (知识图谱关系) ====================
model ContentRelation {
  id          String           @id @default(cuid())
  contentAId  String           // 源文章
  contentBId  String           // 目标文章
  userId      String
  
  relationType RelationType
  strength     Float           // 关联强度 0-1
  
  // 关联详情
  description  String?         // 关联描述："两篇文章都讨论了..."
  evidence     Json?           // 关联证据：["共同关键词: AI", "相似实体: OpenAI"]
  
  // 方向性 (有些关系是有方向的)
  isDirectional Boolean @default(false)
  directionFrom String?         // 如果是有方向的，从哪篇文章指向哪篇
  
  // 元数据
  aiGenerated  Boolean  @default(true)
  userConfirmed Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentA Content @relation("ContentA", fields: [contentAId], references: [id], onDelete: Cascade)
  contentB Content @relation("ContentB", fields: [contentBId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id])

  @@unique([contentAId, contentBId, relationType])
  @@index([userId])
  @@index([contentAId])
  @@index([contentBId])
  @@index([relationType])
  @@map("content_relations")
}

enum RelationType {
  SIMILAR_TOPIC      // 主题相似
  CONTRADICTORY      // 观点冲突/对立
  SUPPORTIVE         // 观点支持/补充
  REFERENCED         // 引用关系 (A引用B)
  SEQUEL             // 续作/后续报道
  SAME_AUTHOR        // 同一作者
  SHARED_ENTITY      // 共享实体 (人物/组织/事件)
  TEMPORAL_CHAIN     // 时间线关联
  CAUSAL             // 因果关系
  BROADER_CONTEXT    // 更广泛的上下文
  NARROWER_FOCUS     // 更聚焦的角度
}

// ==================== 主题聚类模块 ====================
model TopicCluster {
  id          String   @id @default(cuid())
  userId      String
  
  name        String   // 聚类名称 (AI生成或用户定义)
  description String?  // 描述
  keywords    Json?    // 关键词
  
  // 统计
  contentCount Int    @default(0)
  avgQuality   Float? // 平均质量
  
  // 可视化
  color       String   @default("#3b82f6")
  positionX   Float?   // 图谱中的位置
  positionY   Float?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  contents ClusterContent[]

  @@index([userId])
  @@map("topic_clusters")
}

model ClusterContent {
  clusterId String
  contentId String
  
  // 该文章在此聚类中的权重
  relevanceScore Float @default(0.5)
  
  assignedAt DateTime @default(now())

  cluster TopicCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  content Content      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([clusterId, contentId])
  @@index([contentId])
  @@map("cluster_contents")
}

// ==================== 系统配置模块 ====================
model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  isSecret    Boolean  @default(false) // 是否敏感信息（如API密钥）
  category    String   @default("general") // general/llm/embedding等
  updatedAt   DateTime @updatedAt
  updatedBy   String?  // 最后修改的管理员ID

  @@index([category])
  @@map("system_configs")
}
