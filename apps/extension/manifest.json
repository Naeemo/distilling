{
  "manifest_version": 3,
  "name": "InfoDigest - 微信文章收藏",
  "version": "1.0.0",
  "description": "一键保存微信公众号文章到 InfoDigest",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://mp.weixin.qq.com/*",
    "https://mp.weixin.qq.com/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://mp.weixin.qq.com/*",
        "https://mp.weixin.qq.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://infodigest.app/*",
      "https://infodigest.io/*"
    ]
  }
}